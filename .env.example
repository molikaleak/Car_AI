# Warehouse Camera Tracking Configuration Template
# Rename this file to '.env' and fill in your values

# 1. Path Configuration
INPUT_VIDEO_PATH=video2.MP4
MODEL_PATH=yolo11m.pt
OUTPUT_VIDEO_PATH=output_video2.mp4

# 2. Calibrated Gateway Settings
# LINE_POS: 0.0 to 1.0 (e.g., 0.50 for 50% line height, 0.40 for 40%)
LINE_POS=0.50
# LINE_TYPE: horizontal or vertical (Legacy setting, overridden by LINE_ANGLE if specified)
LINE_TYPE=vertical
# LINE_ANGLE: Angle in degrees (e.g. 0 for horizontal, 90 for vertical/90-degree, or custom like 40 for diagonal)
LINE_ANGLE=90
# IN_DIRECTION: down or up (for horizontal line), right or left (for vertical line)
IN_DIRECTION=right

# 3. Model & Hardware Settings
CONFIDENCE_THRESHOLD=0.25
# DEVICE: auto, mps (Apple Silicon GPU), cuda (NVIDIA), or cpu
DEVICE=auto

# 4. Playback & Simulation Settings
# TIME_MODE: auto (uses brightness), day, or night
TIME_MODE=auto
# SLOW_SPEED: 0.5 (for half-speed and stabilized tracking) or 1.0 (normal)
SLOW_SPEED=1.0
# GRAYSCALE: True (converts video to black & white for night testing) or False
GRAYSCALE=True

# 5. ByteTrack Tracker Settings
TRACKER_TYPE=bytetrack
TRACK_HIGH_THRESH=0.50
TRACK_LOW_THRESH=0.1
NEW_TRACK_THRESH=0.50
TRACK_BUFFER=150
MATCH_THRESH=0.8
FUSE_SCORE=True
DETECT_EVERY=10

# 6. Webcam / IP Camera Settings
# CAMERA_IP: IP address or RTSP/HTTP stream URL of your camera. If set, this source will override INPUT_VIDEO_PATH.
# Example for mobile app IP Webcam: http://192.168.1.50:8080/video
# Example for RTSP camera: rtsp://192.168.1.50:5554/live.sdp
# Set to '0' to use your computer's built-in webcam.
CAMERA_IP=0

# SHOW_GUI: Set to True to display the live video tracking window on screen, or False to process in background.
SHOW_GUI=True

# 7. Telegram Bot Settings
# Create your bot via @BotFather in Telegram and set these variables
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 8. Event Recording Settings
# RECORD_CLIPS: True to save short clips (T-5s to T+5s) of crossings, False otherwise
RECORD_CLIPS=True
# CLIP_BUFFER_SECONDS: Seconds to capture before crossing (T-5s)
CLIP_BUFFER_SECONDS=5
# CLIP_DURATION_SECONDS: Seconds to capture after crossing (T+5s)
CLIP_DURATION_SECONDS=5

# TELEGRAM_ALERT_DELAY: Delay in seconds to wait for file writing to fully complete/stabilize before sending (e.g. 120)
TELEGRAM_ALERT_DELAY=120

# 8b. Daily Cleanup Settings
# CLEANUP_INTERVAL_SECONDS: How often to check for old event folders (default 3600 = 1 hour)
CLEANUP_INTERVAL_SECONDS=3600

# 9. Supabase Database Settings
# Set these if you want to log events to Supabase cloud database instead of local SQLite
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# 10. Timezone & Country Settings
# COUNTRY: Used to map to timezones (e.g. Cambodia, Thailand, US)
COUNTRY=Cambodia
# TIMEZONE: Direct IANA timezone name (e.g. Asia/Phnom_Penh, Asia/Bangkok)
TIMEZONE=Asia/Phnom_Penh
